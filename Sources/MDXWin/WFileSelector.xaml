<Window x:Class="MDXWin.WFileSelector"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MDXWin"
        mc:Ignorable="d"
        Title="File selector" Height="720" Width="720" Closing="Window_Closing" PreviewKeyDown="Window_PreviewKeyDown" Background="Black" Foreground="White">
    <Grid>
        <ListBox x:Name="FileList" d:ItemsSource="{d:SampleData ItemCount=5}" BorderThickness="0" MouseUp="Image_MouseUp" Background="Black" Foreground="White" UseLayoutRounding="true">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel>
                        <Image Source="{Binding ViewItem_Line_Image}" ToolTip="{Binding ViewItem_Line_ToolTip}" HorizontalAlignment="Left" VerticalAlignment="Top" Stretch="None" MouseUp="Image_MouseUp" ContextMenuOpening="Image_ContextMenuOpening"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Window>
